# Caddy edge for Water 3D (single-container prod).
#
# One domain, one cert. Caddy serves the static SPA, reverse-proxies the weather
# APIs under /api/* (the prod replacement for the Vite dev proxy in
# frontend/vite.config.ts), and proxies PocketBase under /pb/* to the sibling
# process in the same container. DOMAIN and ACME_EMAIL come from the compose
# environment.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		# Lock down once you've confirmed all sources load. Mapbox, the /api
		# proxies, and /pb are all same-origin now.
		# Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; connect-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
	}

	# --- PocketBase: auth + owner-scoped field storage. handle_path strips the
	#     /pb prefix, so the SDK's https://<domain>/pb base maps onto
	#     PocketBase's own /api/... routes. (The admin dashboard at /_/ is NOT
	#     exposed here — it doesn't render under a subpath; reach it via the
	#     loopback SSH tunnel, see deploy/README.md.) ---
	handle_path /pb/* {
		reverse_proxy 127.0.0.1:8090
	}

	# --- Weather API proxies (handle_path strips the /api/<name> prefix, matching
	#     the Vite dev-proxy rewrites; Host is set to each upstream). ---
	handle_path /api/gridmet/* {
		reverse_proxy https://toolbox-webservices.nkn.uidaho.edu {
			header_up Host toolbox-webservices.nkn.uidaho.edu
		}
	}
	handle_path /api/climate-toolbox/* {
		reverse_proxy https://climate-dev.nkn.uidaho.edu {
			header_up Host climate-dev.nkn.uidaho.edu
		}
	}
	handle_path /api/open-meteo/* {
		reverse_proxy https://archive-api.open-meteo.com {
			header_up Host archive-api.open-meteo.com
		}
	}
	handle_path /api/openet/* {
		reverse_proxy https://openet-api.org {
			header_up Host openet-api.org
		}
	}
	handle_path /api/soil-data-access/* {
		reverse_proxy https://sdmdataaccess.nrcs.usda.gov {
			header_up Host sdmdataaccess.nrcs.usda.gov
		}
	}

	# --- Static SPA (catch-all, evaluated after the /pb and /api handlers) ---
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
