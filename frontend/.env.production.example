# Production frontend config. Copy to `.env.production` and edit the domain +
# Mapbox token, then build the web image (the values are baked into the bundle).
#
#   cp .env.production.example .env.production
#
# NOTE: every VITE_* value ships in the public client bundle — do not put real
# secrets here. The Mapbox pk.* token is public by design; restrict it by URL in
# the Mapbox dashboard.

# --- PocketBase (browser talks to it directly, so it must be a PUBLIC https URL) ---
VITE_POCKETBASE_ENABLED=true
VITE_POCKETBASE_URL=https://pb.YOUR_DOMAIN
VITE_POCKETBASE_FIELDS_COLLECTION=fields
VITE_POCKETBASE_OPENET_CACHE_COLLECTION=openet_cache

# --- Mapbox (URL-restrict this token) ---
VITE_MAPBOX_ACCESS_TOKEN=pk.replace-me
VITE_MAPBOX_STYLE_URL=mapbox://styles/mapbox/satellite-streets-v12

# --- Weather APIs: same-origin /api/* paths that Caddy reverse-proxies in prod ---
# (deploy/Caddyfile maps each of these to its upstream; do not point them at the
#  upstream hosts directly or you'll hit CORS.)
VITE_CLIMATE_TOOLBOX_ENABLED=true
VITE_CLIMATE_TOOLBOX_CFS_PROXY_BASE_URL=/api/climate-toolbox

VITE_GRIDMET_ENABLED=true
VITE_GRIDMET_PROXY_BASE_URL=/api/gridmet

VITE_OPEN_METEO_ENABLED=true
VITE_OPEN_METEO_ARCHIVE_PROXY_BASE_URL=/api/open-meteo

# Disabled by default (need an authenticated proxy before enabling in prod).
VITE_OPENET_ENABLED=false
VITE_SOIL_DATA_ACCESS_ENABLED=false

VITE_DEBUG_DATA_SOURCES=false
